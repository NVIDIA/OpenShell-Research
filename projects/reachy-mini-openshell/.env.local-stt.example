# Local/OpenAI-compatible STT endpoint + Chat Completions model + TTS endpoint.
BACKEND_PROVIDER=local_stt

# Chat Completions model for reasoning and Reachy tool calls.
CHAT_API_KEY=${NVIDIA_INFERENCE_API_KEY}
CHAT_BASE_URL=https://inference-api.nvidia.com/v1
CHAT_MODEL_NAME=azure/anthropic/claude-opus-4-8

# Speech-to-text endpoint. Use not-needed for local no-auth endpoints.
STT_API_KEY=not-needed
STT_BASE_URL=http://127.0.0.1:9000/v1
STT_MODEL_NAME=whisper-1

# Text-to-speech endpoint used for Reachy's spoken reply.
TTS_API_KEY=${OPENAI_API_KEY}
TTS_BASE_URL=https://api.openai.com/v1
TTS_MODEL_NAME=gpt-4o-mini-tts
TTS_VOICE=cedar

# Local STT phrase detection.
MIC_TRANSCRIPTION_RMS_THRESHOLD=500
MIC_TRANSCRIPTION_MIN_AUDIO_MS=250
MIC_TRANSCRIPTION_SILENCE_MS=800
MIC_TRANSCRIPTION_MAX_AUDIO_MS=12000

# Used only with --local-vision.
LOCAL_VISION_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct
HF_HOME=./cache
