OPENAI_API_KEY=${NVIDIA_API_KEY}
OPENAI_BASE_URL=https://inference-api.nvidia.com/v1
MODEL_NAME=azure/anthropic/claude-opus-4-8

# Audio input modes:
# - openai_realtime: microphone audio goes to an OpenAI-compatible Realtime endpoint.
# - riva_stt: microphone audio goes to Riva ASR; final transcripts go to the text LLM path.
# - text: typed input goes to the text LLM path.
AUDIO_INPUT_MODE=text

# Used only when AUDIO_INPUT_MODE=riva_stt.
# Accepts either host:port or http(s)://host:port.
RIVA_SERVER_URI=localhost:50051
# Optional override. Leave unset to infer TLS from an https:// RIVA_SERVER_URI.
# RIVA_USE_SSL=false
RIVA_LANGUAGE_CODE=en-US
RIVA_ASR_MODEL=
RIVA_AUTHORIZATION=
RIVA_METADATA=
RIVA_INTERIM_RESULTS=true
RIVA_AUTOMATIC_PUNCTUATION=true

# Used only with --local-vision.
LOCAL_VISION_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct

HF_HOME=./cache
HF_TOKEN=
