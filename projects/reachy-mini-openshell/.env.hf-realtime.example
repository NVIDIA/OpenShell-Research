# Pollen/Hugging Face realtime voice backend handles speech input, tools, and speech output.
BACKEND_PROVIDER=hf_realtime

# Use the default deployed Pollen session broker.
HF_REALTIME_CONNECTION_MODE=deployed
HF_REALTIME_MODEL=
HF_REALTIME_VOICE=Aiden
HF_TOKEN=

# Optional deployed session broker override. Leave unset for the default Pollen broker.
# HF_REALTIME_SESSION_URL=https://pollen-robotics-reachy-mini-realtime-url.hf.space/session

# For local HF realtime instead, use:
# HF_REALTIME_CONNECTION_MODE=local
# HF_REALTIME_WS_URL=ws://127.0.0.1:8765/v1/realtime

REALTIME_TRANSCRIPTION_LANGUAGE=en

# Used only with --local-vision.
LOCAL_VISION_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct
HF_HOME=./cache
