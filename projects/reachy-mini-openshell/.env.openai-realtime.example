# OpenAI Realtime API handles speech input, tools, and speech output.
# Uses the globally exported OPENAI_API_KEY directly by default.
# Do not paste the global OpenAI key into this file for the normal path.
# Uncomment OPENAI_REALTIME_API_KEY only if this app should use a different key
# from the global OpenAI key.
BACKEND_PROVIDER=openai_realtime

# OPENAI_REALTIME_API_KEY=
OPENAI_REALTIME_BASE_URL=https://api.openai.com/v1
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=cedar

REALTIME_TRANSCRIPTION_LANGUAGE=en

# Used only with --local-vision.
LOCAL_VISION_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct
HF_HOME=./cache
